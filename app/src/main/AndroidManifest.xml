<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLE permissions (Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- BLE permissions (Android < 12) -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />

    <!-- Wi-Fi Direct (legacy media sync; not used in HC-015 runtime) -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Media storage — read recent images/videos for Last Capture Visibility + Gallery -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- Older Android fallback (API < 33) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Microphone (legacy; not used in HC-015 runtime) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Internet (legacy; not used in HC-015 runtime) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Background BLE service (legacy; not invoked in HC-015 runtime) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <!--
        HC-015 — package visibility. Required on Android 11+ for
        getLaunchIntentForPackage(...) to return non-null for unrelated apps.

        New in HC-015:
          - com.sec.android.gallery3d : Samsung Gallery launcher
          - com.google.android.apps.photos : Google Photos launcher
          - <intent ACTION_VIEW image/* and video/*> : Open in Gallery action
            (resolves to whichever gallery app the user has set as default)

        Carried from HC-013:
          - com.google.android.apps.bard, ...gemini, ...googlequicksearchbox
          - com.openai.chatgpt
          - Hey Cyan candidates
          - ACTION_VOICE_COMMAND fallback
    -->
    <queries>
        <!-- Gemini -->
        <package android:name="com.google.android.apps.bard" />
        <package android:name="com.google.android.apps.gemini" />
        <package android:name="com.google.android.googlequicksearchbox" />
        <!-- ChatGPT (kept for compile compat only — UI removed in HC-013) -->
        <package android:name="com.openai.chatgpt" />
        <!-- Hey Cyan candidates -->
        <package android:name="com.heycyan.app" />
        <package android:name="com.heyx.heycyan" />
        <package android:name="io.heycyan.app" />
        <package android:name="com.oudmon.heycyan" />
        <package android:name="com.cyan.glasses" />
        <!-- HC-015: Samsung Gallery + Google Photos -->
        <package android:name="com.sec.android.gallery3d" />
        <package android:name="com.google.android.apps.photos" />

        <!-- ACTION_VIEW for media so we can resolve the user's default gallery -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="video/*" />
        </intent>
        <!-- Voice assistant fallback for Open Gemini -->
        <intent>
            <action android:name="android.intent.action.VOICE_COMMAND" />
        </intent>
    </queries>

    <application
        android:name=".CyanGemApplication"
        xmlns:tools="http://schemas.android.com/tools"
        android:allowBackup="false"
        tools:replace="android:allowBackup"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="CyanGem"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.CyanGem"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.CyanGem"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".ble.BleConnectionService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

    </application>
</manifest>
