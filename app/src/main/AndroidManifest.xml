<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLE permissions (Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- BLE permissions (Android < 12) -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />

    <!-- Wi-Fi (legacy; not used in HC-019 stable runtime) -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Media storage — Capture Check, Capture Sessions, Gallery -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Foreground notifications for the BLE service -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Internet — declared but not used by HC-019 stable runtime -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Background BLE service (legacy; HC-019 does not start it) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <!--
        HC-019 — package visibility.
        ADDS: com.glasssutdio.wear (HeyCyan candidate from Juan's technical
        fix-forward document).
        Other queries unchanged from HC-018.
    -->
    <queries>
        <!-- Gemini -->
        <package android:name="com.google.android.apps.bard" />
        <package android:name="com.google.android.apps.gemini" />
        <package android:name="com.google.android.googlequicksearchbox" />
        <!-- ChatGPT (kept for compile compat with dormant code only) -->
        <package android:name="com.openai.chatgpt" />
        <!-- HeyCyan candidates -->
        <package android:name="com.glasssutdio.wear" />
        <package android:name="com.heycyan.app" />
        <package android:name="com.heyx.heycyan" />
        <package android:name="io.heycyan.app" />
        <package android:name="com.oudmon.heycyan" />
        <package android:name="com.cyan.glasses" />
        <!-- Gallery apps -->
        <package android:name="com.sec.android.gallery3d" />
        <package android:name="com.google.android.apps.photos" />

        <!-- ACTION_VIEW for media -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="video/*" />
        </intent>
        <!-- ACTION_SEND for share-sheet resolution -->
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="video/*" />
        </intent>
        <!-- Voice assistant fallback for Open Gemini -->
        <intent>
            <action android:name="android.intent.action.VOICE_COMMAND" />
        </intent>
    </queries>

    <application
        android:name=".CyanGemApplication"
        xmlns:tools="http://schemas.android.com/tools"
        android:allowBackup="false"
        tools:replace="android:allowBackup"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="CyanGem"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.CyanGem"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.CyanGem"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".ble.BleConnectionService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

    </application>
</manifest>
